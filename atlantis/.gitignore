# Atlantis .gitignore

# Sensitive files
atlantis-secrets.txt
*.token
*.secret

# Backup files
*.bak
*.backup

# Terraform files
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/tfplan
terraform/*.tfplan

# Kubernetes secrets (keep the template, ignore populated versions)
k8s/secret-populated.yaml

# Logs
*.log
atlantis.log

# Temporary files
*.tmp
.DS_Store
